        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="JSR223 Sampler" enabled="false">
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="script">def sb = new StringBuilder()

sb.append(&quot;timeStamp=&quot;).append(System.currentTimeMillis()).append(&quot;, &quot;)
sb.append(&quot;elapsed=&quot;).append(prev.getTime()).append(&quot;, &quot;)
sb.append(&quot;label=&quot;).append(prev.getSampleLabel()).append(&quot;, &quot;)
sb.append(&quot;responseCode=&quot;).append(prev.getResponseCode()).append(&quot;, &quot;)
sb.append(&quot;responseMessage=&quot;).append(prev.getResponseMessage()).append(&quot;, &quot;)
sb.append(&quot;threadName=&quot;).append(Thread.currentThread().getName()).append(&quot;, &quot;)
sb.append(&quot;dataType=&quot;).append(prev.getDataType()).append(&quot;, &quot;)
sb.append(&quot;success=&quot;).append(prev.isSuccessful()).append(&quot;, &quot;)
sb.append(&quot;failureMessage=&quot;).append(prev.getResponseMessage()).append(&quot;, &quot;)
sb.append(&quot;bytes=&quot;).append(prev.getBytesAsLong()).append(&quot;, &quot;)
sb.append(&quot;sentBytes=&quot;).append(prev.getSentBytes()).append(&quot;, &quot;)
sb.append(&quot;grpThreads=&quot;).append(ctx.getThreadGroup().getNumThreads()).append(&quot;, &quot;)
sb.append(&quot;allThreads=&quot;).append(org.apache.jmeter.threads.JMeterContextService.getNumberOfThreads()).append(&quot;, &quot;)
sb.append(&quot;URL=&quot;).append(prev.getUrlAsString()).append(&quot;, &quot;)
sb.append(&quot;Latency=&quot;).append(prev.getLatency()).append(&quot;, &quot;)
sb.append(&quot;Hostname=&quot;).append(java.net.InetAddress.localHost.hostName).append(&quot;, &quot;)
sb.append(&quot;IdleTime=&quot;).append(prev.getIdleTime()).append(&quot;, &quot;)
sb.append(&quot;Connect=&quot;).append(prev.getConnectTime())

log.info(sb.toString())</stringProp>
          <stringProp name="scriptLanguage">groovy</stringProp>
        </JSR223Sampler>
